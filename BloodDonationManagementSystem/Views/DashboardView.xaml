<UserControl x:Class="BloodDonationManagementSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF7F9FC" Offset="0"/>
            <GradientStop Color="#FFFFE9EE" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFCD2E4B"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFB7243F"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF1F2A44"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF7B8191"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Width="520"
                Padding="36"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE5EAF2"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="DashboardTitle"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TitleBrush}"
                           TextAlignment="Center"/>
                <TextBlock x:Name="WelcomeText"
                           Margin="0,8,0,28"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"/>

                <Button Content="Logout"
                        Click="Logout_Click"
                        Width="150"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>

