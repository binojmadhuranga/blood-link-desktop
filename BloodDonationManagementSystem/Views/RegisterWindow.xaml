<Window x:Class="BloodDonationManagementSystem.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register"
        Height="300"
        Width="400">

    <StackPanel Margin="20">

        <TextBlock Text="Username" Margin="5"/>
        <TextBox x:Name="UsernameBox" Margin="5"/>

        <TextBlock Text="Password" Margin="5"/>
        <PasswordBox x:Name="PasswordBox" Margin="5"/>

        <TextBlock Text="Select Role" Margin="5"/>
        <ComboBox x:Name="RoleBox" Margin="5">
            <ComboBoxItem Content="Donor"/>
            <ComboBoxItem Content="Hospital"/>
        </ComboBox>

        <Button Content="Register"
                Click="Register_Click"
                Margin="5"
                Height="35"/>

    </StackPanel>

</Window>
