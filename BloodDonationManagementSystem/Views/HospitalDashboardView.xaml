<UserControl x:Class="BloodDonationManagementSystem.Views.HospitalDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF4F8FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFB91C3D"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFA61B37"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF18243C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF6C7488"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FF334155"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFE3EAF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE3EAF4"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Hospital Dashboard"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock x:Name="WelcomeText"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="OpenRequestPanelButton" Content="Request Donor"
                                Margin="0,0,10,0"
                                Width="140"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="RefreshButton" Content="Refresh"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="LogoutButton" Content="Logout"
                                Width="120"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </DockPanel>

                <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,18">
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Requests Sent" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock x:Name="RequestsSentText" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Pending" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock x:Name="PendingText" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="16" Padding="18" Background="#FFF5F8FF" BorderBrush="#FFD9E2F5" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Available Donors" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock x:Name="DonorsAvailableText" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="16" CornerRadius="16" Background="#FFF8FAFE" BorderBrush="#FFE3EAF4" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Request Flow" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Margin="0,0,0,14"/>
                            <TextBlock Text="1. Click 'Request Donor'." FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="2. Select one or more registered donors." FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="3. Click Register to send requests." FontSize="13" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="16" CornerRadius="16" Background="#FFF8FAFE" BorderBrush="#FFE3EAF4" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Your Requests" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Margin="0,0,0,12"/>
                            <DataGrid x:Name="HospitalRequestsGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FFF5F7FB">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Donor" Binding="{Binding DonorName}" Width="*"/>
                                    <DataGridTextColumn Header="Group" Binding="{Binding BloodGroup}" Width="90"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="220"/>
                                    <DataGridTextColumn Header="Requested" Binding="{Binding RequestedAt, StringFormat=dd-MMM-yyyy HH:mm}" Width="170"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


