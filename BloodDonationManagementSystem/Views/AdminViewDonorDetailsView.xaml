<UserControl x:Class="BloodDonationManagementSystem.Views.AdminViewDonorDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F8FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B5BDB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF314ED0"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF18243C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF6C7488"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="#FFF8FAFE"/>
            <Setter Property="BorderBrush" Value="#FFE3EAF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE3EAF4"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Donor Details"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TitleBrush}"/>
                            <TextBlock x:Name="DonorNameDisplay"
                                       Margin="0,4,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>

                        <Button x:Name="BackButton" 
                                Content="Back" 
                                DockPanel.Dock="Right"
                                Width="100"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Style="{StaticResource InfoCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Blood Group" 
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       x:Name="BloodGroupDisplay"
                                       Foreground="{StaticResource TitleBrush}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="Contact Number" 
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       x:Name="ContactDisplay"
                                       Foreground="{StaticResource TitleBrush}"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource InfoCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Location" 
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       x:Name="LocationDisplay"
                                       Foreground="{StaticResource TitleBrush}"
                                       FontSize="14"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="Last Donation Date" 
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       x:Name="LastDonationDisplay"
                                       Foreground="{StaticResource TitleBrush}"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Padding="16"
                            CornerRadius="16"
                            Background="#FFF8FAFE"
                            BorderBrush="#FFE3EAF4"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Blood Requests History"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TitleBrush}"
                                       Margin="0,0,0,12"/>

                            <DataGrid x:Name="RequestsGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FFF5F7FB"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Hospital" Binding="{Binding HospitalName}" Width="150"/>
                                    <DataGridTextColumn Header="Blood Group" Binding="{Binding BloodGroup}" Width="100"/>
                                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTextColumn Header="Requested" Binding="{Binding RequestedAt, StringFormat=dd-MMM-yyyy HH:mm}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

