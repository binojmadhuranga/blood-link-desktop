<UserControl x:Class="BloodDonationManagementSystem.Views.HospitalDonorRequestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF4F8FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFB91C3D"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFA61B37"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#FF334155"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#FF1E293B"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF18243C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF6C7488"/>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FFF9FBFF"/>
            <Setter Property="BorderBrush" Value="#FFD9E2F1"/>
            <Setter Property="BorderThickness" Value="1.3"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE3EAF4"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Request Donors"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock x:Name="PageInfoText"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BackButton" Content="Back"
                                Width="120"
                                Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="LogoutButton" Content="Logout"
                                Width="120"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="16" CornerRadius="16" Background="#FFF8FAFE" BorderBrush="#FFE3EAF4" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Registered Donors" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                            <TextBlock x:Name="SelectionInfoText" Grid.Row="1" Margin="0,6,0,12" Foreground="{StaticResource MutedBrush}"/>

                            <ListBox x:Name="DonorListBox"
                                     Grid.Row="2"
                                     SelectionMode="Extended"
                                     Background="White"
                                     BorderBrush="#FFD9E2F1"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="4" CornerRadius="10" BorderBrush="#FFE3EAF4" BorderThickness="1" Background="#FFFDFEFF">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}"/>
                                                    <TextBlock Text="{Binding Location}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="10,4" CornerRadius="12" Background="#FFF0F9FF" BorderBrush="#FFD7EAF8" BorderThickness="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BloodGroup}" FontWeight="SemiBold" Foreground="#FF0C4A6E"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Padding="16" CornerRadius="16" Background="#FFF8FAFE" BorderBrush="#FFE3EAF4" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Send Request" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Margin="0,0,0,14"/>

                            <TextBlock Text="Quantity (units)" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="QuantityBox" Style="{StaticResource InputStyle}" Text="1"/>

                            <TextBlock Text="Notes (optional)" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="NotesBox" Height="110" Margin="0,0,0,14" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                            <Button x:Name="RegisterRequestButton" Content="Request" Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

