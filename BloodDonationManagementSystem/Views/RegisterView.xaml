<UserControl x:Class="BloodDonationManagementSystem.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF4F7FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFD63A57"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFC92E4A"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF1F2A44"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF7B8191"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FFD7DCE6"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFF9FAFC"/>

        <Style x:Key="InputBoxStyle" TargetType="Control">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Foreground" Value="#FF202738"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Width="460"
                Padding="34"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE5EAF2"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#2619202D" BlurRadius="24" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Create Account"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TitleBrush}"/>
                <TextBlock Text="Create your donor or hospital account in seconds"
                           Margin="0,8,0,26"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"/>

                <Grid>
                    <TextBox x:Name="UsernameBox" Style="{StaticResource InputBoxStyle}"/>
                    <TextBlock Text="Username"
                               Margin="14,0,0,14"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3B3"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=UsernameBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=UsernameBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 GotFocus="PasswordBox_OnFocusChanged"
                                 LostFocus="PasswordBox_OnFocusChanged"/>
                    <TextBlock x:Name="PasswordPlaceholder"
                               Text="Password"
                               Margin="14,0,0,14"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3B3"
                               IsHitTestVisible="False"
                               Visibility="Visible"/>
                </Grid>

                <Grid>
                    <TextBox x:Name="ContactNumberBox" Style="{StaticResource InputBoxStyle}"/>
                    <TextBlock Text="Contact number"
                               Margin="14,0,0,14"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3B3"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=ContactNumberBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=ContactNumberBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <TextBox x:Name="LocationBox" Style="{StaticResource InputBoxStyle}"/>
                    <TextBlock Text="Location"
                               Margin="14,0,0,14"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3B3"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=LocationBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=LocationBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <ComboBox x:Name="RoleBox"
                              Style="{StaticResource InputBoxStyle}"
                              SelectionChanged="RoleBox_OnSelectionChanged">
                        <ComboBoxItem Content="Donor" Tag="Donor"/>
                        <ComboBoxItem Content="Hospital" Tag="Hospital"/>
                    </ComboBox>
                    <TextBlock x:Name="RolePlaceholder"
                               Text="Select role"
                               Margin="14,0,0,14"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3B3"
                               IsHitTestVisible="False"
                               Visibility="Visible"/>
                </Grid>

                <Button Content="Create account"
                        Click="Register_Click"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,8,0,16"/>

                <Button Content="Already have an account? Login"
                        Click="OpenLogin_Click"
                        Style="{StaticResource LinkButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>

