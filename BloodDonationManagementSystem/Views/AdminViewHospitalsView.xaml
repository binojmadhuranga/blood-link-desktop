<UserControl x:Class="BloodDonationManagementSystem.Views.AdminViewHospitalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F8FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B5BDB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF314ED0"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFE63946"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#FFD62828"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFFFA500"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF06A77D"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF18243C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF6C7488"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE59400"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE3EAF4"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Manage Hospitals"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock Text="View, edit, and manage all registered hospitals"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="RefreshButton" 
                                Content="Refresh" 
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="BackButton" 
                                Content="Back to Dashboard" 
                                Width="150"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Padding="14"
                        CornerRadius="12"
                        Background="#FFF0F4FF"
                        BorderBrush="#FFD9E2F5"
                        BorderThickness="1">
                    <TextBlock Text="Total Hospitals" 
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <Border Grid.Row="2"
                        Padding="16"
                        CornerRadius="16"
                        Background="#FFF8FAFE"
                        BorderBrush="#FFE3EAF4"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="HospitalsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FFF5F7FB"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Hospital Name" Binding="{Binding Name}" Width="150"/>
                                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="140"/>
                                <DataGridTextColumn Header="Contact" Binding="{Binding ContactNumber}" Width="120"/>
                                <DataGridTextColumn Header="Requests" Binding="{Binding RequestCount}" Width="80"/>
                                <DataGridTemplateColumn Header="Actions" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4">
                                                <Button x:Name="ViewButton" 
                                                        Content="View" 
                                                        Margin="0,0,4,0"
                                                        Padding="8,0"
                                                        Height="28"
                                                        FontSize="11"
                                                        Background="{StaticResource SuccessBrush}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="ViewHospital_Click"
                                                        Tag="{Binding Id}"/>
                                                <Button x:Name="EditButton" 
                                                        Content="Edit" 
                                                        Margin="0,0,4,0"
                                                        Padding="8,0"
                                                        Height="28"
                                                        FontSize="11"
                                                        Background="{StaticResource WarningBrush}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="EditHospital_Click"
                                                        Tag="{Binding Id}"/>
                                                <Button x:Name="DeleteButton" 
                                                        Content="Delete" 
                                                        Padding="8,0"
                                                        Height="28"
                                                        FontSize="11"
                                                        Background="{StaticResource DangerBrush}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="DeleteHospital_Click"
                                                        Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

