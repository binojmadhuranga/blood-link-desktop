<UserControl x:Class="BloodDonationManagementSystem.Views.AdminEditHospitalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F8FF" Offset="0"/>
            <GradientStop Color="#FFFFEEF2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B5BDB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF314ED0"/>
        <SolidColorBrush x:Key="TitleBrush" Color="#FF18243C"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF6C7488"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TitleBrush}"/>
            <Setter Property="Background" Value="#FFFAFBFC"/>
            <Setter Property="BorderBrush" Value="#FFE3EAF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TitleBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Background="{StaticResource CardBrush}"
                CornerRadius="18"
                BorderBrush="#FFE3EAF4"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Edit Hospital"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"/>
                        <TextBlock Text="Update hospital information"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,20,0,0"
                            Padding="20"
                            CornerRadius="14"
                            Background="#FFF8FAFE"
                            BorderBrush="#FFE3EAF4"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Hospital Name" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="NameInput" 
                                     Grid.Row="0" 
                                     Grid.Column="0" 
                                     Margin="0,0,10,12"
                                     Style="{StaticResource InputFieldStyle}"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Location" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="LocationInput" 
                                     Grid.Row="0" 
                                     Grid.Column="1" 
                                     Style="{StaticResource InputFieldStyle}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Contact Number" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="ContactNumberInput" 
                                     Grid.Row="1" 
                                     Grid.Column="0" 
                                     Margin="0,0,10,0"
                                     Style="{StaticResource InputFieldStyle}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="CancelButton" 
                                Content="Cancel" 
                                Margin="0,0,10,0"
                                Height="40"
                                Padding="24,0"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TitleBrush}"
                                Background="White"
                                BorderBrush="#FFE3EAF4"
                                BorderThickness="1"
                                Cursor="Hand"/>
                        <Button x:Name="SaveButton" 
                                Content="Save Changes" 
                                Height="40"
                                Padding="24,0"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

